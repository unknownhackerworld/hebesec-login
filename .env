# =======================
# SERVER
# =======================
PORT=5000
NODE_ENV=development
API_BASE_URL=/api

# =======================
# POSTGRES CONFIG
# =======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=postgres
DB_PASSWORD=SuperSecurePassword123
DB_SSL=false

# =======================
# AUTH
# =======================
JWT_SECRET=super_long_secure_random_string_123456789
JWT_EXPIRES_IN=7d

# =======================
# SECURITY
# =======================
BCRYPT_SALT_ROUNDS=10

# =======================
# CLIENT
# =======================
CLIENT_URL=http://localhost:3000

# =======================
# OPTIONAL SERVICES
# =======================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# =======================
# EMAIL (optional)
# =======================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=test_user
SMTP_PASS=test_pass

# =======================
# THIRD PARTY
# =======================
STRIPE_API_KEY=sk_test_example
AWS_ACCESS_KEY_ID=AKIAEXAMPLE
AWS_SECRET_ACCESS_KEY=secretExample